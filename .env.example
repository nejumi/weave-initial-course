# ──────────────────────────────────────────────────────────
# W&B 接続設定
# ──────────────────────────────────────────────────────────

# Dedicated Cloud を使う場合のみ設定（コメントアウトまたは空欄 → SaaS を使用）
# WANDB_BASE_URL=https://your-org.wandb.io

# W&B API キー（必須）
WANDB_API_KEY=your_wandb_api_key_here

# エンティティ名（ユーザー名 or チーム名）（必須）
WANDB_ENTITY=your_entity

# プロジェクト名（省略時: weave-course）
# WANDB_PROJECT=weave-course

# ──────────────────────────────────────────────────────────
# OpenAI 設定
# ──────────────────────────────────────────────────────────

OPENAI_API_KEY=your_openai_api_key_here
